# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for the High-Fashion Disparity Tracker
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# Prisma + Supabase Postgres
# Get these from: Supabase Dashboard → Project Settings → Database → Connection string
#
# DATABASE_URL uses the transaction pooler (port 6543) — used by the app at runtime.
#   Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_DATABASE_URL uses the session pooler (port 5432) — used by Prisma migrations / db push.
#   Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxxxxxxx:your-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_DATABASE_URL="postgresql://postgres.xxxxxxxxxxxxxxxxx:your-password@aws-0-region.pooler.supabase.com:5432/postgres"

# Public site URL — set on Vercel to the production domain
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: analytics engine URL (Bun mini-service). Only used if you run the
# Docker composition — Vercel deployment uses embedded Next.js API routes.
ANALYTICS_ENGINE_URL="http://localhost:3030"
